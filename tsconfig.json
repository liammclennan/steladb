{

  "include": ["src/**/*"],
  "exclude": ["node_modules"],


  "compilerOptions": {
    "lib": ["esnext","dom"],
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "nodenext",
    "target": "esnext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node16",
    "forceConsistentCasingInFileNames": true
  }
}